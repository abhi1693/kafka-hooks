APP_ENV=development
LOG_LEVEL=INFO

WEBHOOK_PROVIDER=github
WEBHOOK_SOURCE=github
WEBHOOK_PATH=/webhooks/github
WEBHOOK_SECRET=change-me
# Optional comma-separated rotation/fan-in secrets. WEBHOOK_SECRET is checked
# first when both are configured.
WEBHOOK_SECRETS=
WEBHOOK_MAX_BODY_BYTES=27262976
ENVELOPE_INCLUDE_PAYLOAD=true
ENVELOPE_INCLUDE_HEADERS=false
WEBHOOK_EVENT_ALLOWLIST=
WEBHOOK_EVENT_DENYLIST=
WEBHOOK_SUCCESS_STATUS_CODE=202
WEBHOOK_PUBLISH_PING=false

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_DEFAULT=github.webhooks.events.v1
KAFKA_TOPIC_ROUTES={"installation":"github.webhooks.installations.v1","installation_repositories":"github.webhooks.installations.v1"}
# Optional format template used after KAFKA_TOPIC_ROUTES. Examples:
# KAFKA_TOPIC_TEMPLATE={source}.{event_type}
# KAFKA_TOPIC_TEMPLATE={source}.{event_type}.{repository_owner}
KAFKA_TOPIC_TEMPLATE=
KAFKA_KEY_STRATEGY=installation_repository
KAFKA_STATIC_HEADERS={}
KAFKA_INCLUDE_PROVIDER_HEADERS=true
KAFKA_CLIENT_ID=kafka-hooks
KAFKA_ACKS=all
KAFKA_REQUEST_TIMEOUT_MS=10000
KAFKA_LINGER_MS=5
KAFKA_MAX_REQUEST_SIZE=29360128
KAFKA_MAX_BATCH_SIZE=29360128
KAFKA_ENABLE_IDEMPOTENCE=true
KAFKA_COMPRESSION_TYPE=

# SASL example:
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SASL_MECHANISM=PLAIN
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=
